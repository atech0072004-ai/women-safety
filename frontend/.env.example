# SafeHer Frontend Environment Variables Configuration
# Replace these values with your actual credentials from the Supabase Console

# Find these in Supabase under Project Settings > API
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Express Backend URL (defaults to http://localhost:5000)
VITE_BACKEND_URL=http://localhost:5000

# Optional: Add your Google Maps API Key to load live maps (falls back to mock location radar if empty)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
