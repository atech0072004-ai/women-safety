        </tr>
        <tr>
            <td>&nbsp;&nbsp;├── server.js</td>
            <td>File</td>
            <td>Main API routes, in-memory fallbacks, and server initialization.</td>
        </tr>
        <tr>
            <td>&nbsp;&nbsp;└── setup.sql</td>
            <td>File</td>
            <td>Database table definitions and Row-Level Security (RLS) policies.</td>
        </tr>
        <tr>
            <td><strong>frontend/</strong></td>
